APP_NAME=LLM Ops
ENV=dev
LOG_LEVEL=INFO

# Model routing
DEFAULT_MODEL=text-main
FALLBACK_MODEL=text-fallback
MULTIMODAL_MODEL=vision-main

# Version tracking
PROMPT_VERSION=grounded_answer:v1
RETRIEVER_VERSION=hybrid:v1
POLICY_VERSION=policy:v1

# Vector DB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=llm_ops_docs

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ────────────────────────────────────────────────────────────────────────
# Generation backend.
#   template      — stitch retrieved chunks into a citation-tagged answer (no LLM, no key needed).
#                   Useful for "clone and run without a key" demos.
#   openai_compat — call any OpenAI-compatible /v1/chat/completions endpoint (OpenAI, vLLM, LM Studio).
#   ollama        — call a local Ollama server.
#
# For demo with gpt-4o-mini:
#   GENERATION_BACKEND=openai_compat
#   LLM_BASE_URL=https://api.openai.com
#   LLM_MODEL_NAME=gpt-4o-mini
#   OPENAI_API_KEY=sk-...
#
# Streamlit Cloud: paste these in the app's Secrets panel (they auto-load as env vars).
# Railway/Render:  set them as project env vars.
# GitHub Actions:  set as repo Secrets, reference via ${{ secrets.OPENAI_API_KEY }}.
# ────────────────────────────────────────────────────────────────────────
GENERATION_BACKEND=template
LLM_BASE_URL=https://api.openai.com
LLM_MODEL_NAME=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# Required when GENERATION_BACKEND=openai_compat AND LLM_BASE_URL points at OpenAI.
# Leave blank for template mode or local Ollama.
OPENAI_API_KEY=

# Dashboard -> API wiring.
# Local:           http://localhost:8000
# Streamlit Cloud: deployed backend URL (Railway/Render/Fly).
API_BASE_URL=http://localhost:8000

# Reranker backend: tfidf | cross_encoder
RERANKER_BACKEND=tfidf
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Verification
VERIFICATION_BACKEND=tfidf
GROUNDING_THRESHOLD=0.3

# Data
SAMPLE_DATA_DIR=./data/sample_docs
